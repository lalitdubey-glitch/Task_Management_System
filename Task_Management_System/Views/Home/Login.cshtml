@{
}

<div class="container">
    <div class="row mx-auto shadow p-5 rounded-pill justify-content-center">
        <form method="post" id="loginForm">
            <h2 class="text-primary text-center">Login</h2>
            <div class="col-lg-6 col-md-8 col-sm-12 mx-auto">
                <label>Email</label>
                <input type="email" name="email" id="email" placeholder="example@gmail.com" class="form-control" />
                <label class="mt-2">Password</label> <input type="password" name="pass" id="pass" placeholder="•••••••" class="form-control" />

                <input type="button" value="Login" id="BtnLogin" class="btn btn-primary d-block mx-auto my-4" />
            </div>
        </form>
    </div>
</div>